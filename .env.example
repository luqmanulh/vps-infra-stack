# Domain settings
DOMAIN_MAIN=example.com
ACME_EMAIL=admin@example.com

# Dashboard auth (generate with: htpasswd -nb admin <password>)
TRAEFIK_AUTH=admin:your_htpasswd_hash_here

# Service tags
FORGEJO_TAG=15
TRAEFIK_TAG=v3.6
UPTIME_KUMA_TAG=2

# Security / Secrets (Generate strong random strings for actual .env)
FORGEJO_DB_PASSWORD=your_secure_password
